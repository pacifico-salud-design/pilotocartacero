{
  "redirects": [
    { "source": "/", "destination": "/pages/sanna-app/home.html", "permanent": false },
    { "source": "/index.html", "destination": "/pages/sanna-app/home.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/tokens/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
